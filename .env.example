APP_ENV=dev
APP_SECRET=change-me

# Database
DATABASE_URL="mysql://user:password@127.0.0.1:3306/database_name?serverVersion=8.0.32&charset=utf8mb4"

# Mailer / Messenger
MAILER_DSN=smtp://user:password@smtp.example.com:587
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Google OAuth / Calendar
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/connect/google/callback
GOOGLE_CALENDAR_CREDENTIALS=%kernel.project_dir%/config/google_client_secret.json

# Third-party APIs
RECAPTCHA_SECRET_KEY=your-recaptcha-secret
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
DEEPINFRA_API_KEY=your-deepinfra-api-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
WEATHER_API_KEY=your-weather-api-key
TOKEN_SECRET=your-token-secret
PERSPECTIVE_API_KEY=your-perspective-api-key
IBM_WATSON_API_KEY=your-ibm-watson-api-key
IBM_WATSON_SERVICE_URL=https://api.example.com/ibm-watson-instance
ABLY_API_KEY=your-ably-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your-jwt-passphrase
